{
  "name": "telegram-job-aggregator",
  "version": "1.0.0",
  "private": true,
  "description": "AI-assisted Telegram job scraping, extraction & filtering PWA",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @tja/db run generate",
    "db:migrate": "pnpm --filter @tja/db run migrate && pnpm --filter @tja/db run migrate:fts",
    "db:migrate:fts": "pnpm --filter @tja/db run migrate:fts",
    "db:seed": "pnpm --filter @tja/db run seed",
    "scrape:once": "pnpm --filter @tja/worker run scrape:once",
    "worker": "pnpm --filter @tja/worker run start",
    "api": "pnpm --filter @tja/api run start",
    "web": "pnpm --filter @tja/web run dev"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
