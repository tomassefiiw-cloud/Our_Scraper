{
  "name": "@tja/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:fts": "prisma db execute --file prisma/fts.sql --schema prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts",
    "studio": "prisma studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "@tja/shared": "workspace:*"
  },
  "devDependencies": {
    "prisma": "^5.18.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0"
  }
}
