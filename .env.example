# =============================================================================
# TELEGRAM JOB AGGREGATOR — Environment Variables
# Copy to .env and fill in your values.
# =============================================================================

# ---- Database (PostgreSQL / Supabase) ----
# Local docker-compose:
DATABASE_URL=postgresql://tja:tja@localhost:5432/tja?schema=public
# Supabase (production example):
# DATABASE_URL=postgresql://postgres.xxxx:password@db.xxxx.supabase.co:5432/postgres
DIRECT_URL=postgresql://tja:tja@localhost:5432/tja?schema=public

# ---- Redis (Upstash / local) ----
REDIS_URL=redis://localhost:6379

# ---- Auth ----
JWT_SECRET=change-me-to-a-32-char-random-string
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- AI Providers (fill in the ones you have) ----
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_MODEL=gemini-1.5-flash-latest

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-haiku-20240307

OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-flash-1.5

KIMI_API_KEY=
KIMI_MODEL=moonshot-v1-8k

# ---- Ollama (local fallback) ----
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi4:latest

# ---- App config ----
NODE_ENV=development
PORT=4000
SCRAPE_INTERVAL_MINUTES=30
MAX_DEEP_LINK_DEPTH=3
PUPPETEER_TIMEOUT=30000
PUPPETEER_HEADLESS=true

# ---- Public API base (for PWA) ----
NEXT_PUBLIC_API_URL=http://localhost:4000

# ---- Push Notifications (VAPID) ----
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ---- Web (Next.js) ----
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
