# =============================================================================
# Telegram Job Aggregator — Environment Variables
# Copy to .env (for local dev) or set in Vercel project settings.
# All AI provider keys stay SERVER-SIDE — they're only used by /api/extract.
# =============================================================================

# ---- AI Providers (set as many as you have) ----
# Free tier recommendations: Gemini (best) → Groq (fast) → DeepSeek → OpenRouter
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash-latest

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-flash-1.5

KIMI_API_KEY=
KIMI_MODEL=moonshot-v1-8k

OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-haiku-20240307

# Local fallback (only if you run Ollama locally)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi4:latest

# ---- App config (optional) ----
NODE_ENV=development
