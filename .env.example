# =============================================================================
# Telegram Job Aggregator — Environment Variables
# Copy to .env (for local dev) or set in Vercel project settings.
# All AI provider keys stay SERVER-SIDE — they're only used by /api/extract.
# =============================================================================

# ---- AI Providers (set as many as you have) ----
#
# REGION-BLOCKED USERS (Ethiopia, etc.):
# Gemini, Groq, OpenAI, and Claude are blocked in some regions (return 403).
# Use OpenRouter or DeepSeek instead — they work globally.
#
# RECOMMENDED: OpenRouter (works everywhere, has free models)
#   1. Go to https://openrouter.ai
#   2. Sign in, create a key (starts with sk-or-v1-...)
#   3. Set OPENROUTER_API_KEY below
#   4. Default model is free: meta-llama/llama-3.1-8b-instruct:free
#
# MULTIPLE GEMINI KEYS — LOAD BALANCING (only works if Gemini isn't region-blocked):
# Each free Gemini key gets 1500 req/day. To get more capacity, create multiple
# keys from different Google accounts and add them as GEMINI_API_KEY_2, _3, etc.
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_MODEL=gemini-2.0-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# OpenRouter — works in all regions. Free models available.
# Get a key at https://openrouter.ai — starts with sk-or-v1-...
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-flash-1.5

KIMI_API_KEY=
KIMI_MODEL=moonshot-v1-8k

OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-haiku-20240307

# Local fallback (only if you run Ollama locally)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi4:latest

# ---- App config (optional) ----
NODE_ENV=development
