# =============================================================================
# Telegram Job Aggregator — Environment Variables
# =============================================================================
# Copy to .env (for local dev) or set in Vercel project settings.
# All AI provider keys stay SERVER-SIDE — they're only used by /api/extract.
# =============================================================================

# ---- AI Providers (set at least ONE) ----
#
# RECOMMENDED: DeepSeek — generous free tier ($5.50 credit, ~6 months)
#   1. Go to https://platform.deepseek.com
#   2. Sign up with Google or email
#   3. Click "API Keys" → "Create API Key"
#   4. Copy the key (starts with "sk-...")
#   5. New users get $5.50 free credit — that's ~37K extraction requests!
#   6. Works globally (no region blocks)
#
# Why not Gemini/Groq/OpenAI/Claude?
#   These are region-blocked in many areas (Ethiopia, etc.) — they return
#   403 Forbidden or quota=0 even with a valid key. DeepSeek and Mistral
#   work globally and have generous free tiers.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ALTERNATIVE: Mistral — free tier, works globally
#   Sign up at https://console.mistral.ai
#   Free tier has rate limits but no daily request cap.
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# FALLBACK: OpenRouter — works globally but free tier limited to 50 req/day
#   Sign up at https://openrouter.ai
#   Only useful as a backup if DeepSeek + Mistral run out.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

# OTHER (uncomment if needed)
# KIMI_API_KEY=
# KIMI_MODEL=moonshot-v1-8k
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=phi4:latest

# ---- App config ----
NODE_ENV=development
